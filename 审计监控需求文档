```go
// AuditExportTask 导出任务
type AuditExportTask struct {
    ID         string `json:"id"`
    CreatorID  string `json:"creator_id"`
    CreateTime string `json:"create_time"`
    Status     string `json:"status"`   // PENDING/RUNNING/SUCCESS/FAIL
    Format     string `json:"format"`
    FilterJSON string `json:"filter_json"`
    FileName   string `json:"file_name"`
    FileHash   string `json:"file_hash"`
    FailReason string `json:"fail_reason"`
    FinishTime string `json:"finish_time"`
}

// CreateAuditExportTask 创建导出任务
// args: [AuditExportTask JSON]
func CreateAuditExportTask(stub shim.ChaincodeStubInterface, args []string) pb.Response {
    if len(args) != 1 {
        return shim.Error("参数个数不满足")
    }

    var task AuditExportTask
    if err := json.Unmarshal([]byte(args[0]), &task); err != nil {
        return shim.Error(fmt.Sprintf("任务解析失败: %v", err))
    }

    if task.ID == "" {
        task.ID = stub.GetTxID()[:16]
    }
    task.Status = "PENDING"
    task.CreateTime = time.Now().Format("2006-01-02 15:04:05")

    if err := utils.WriteLedger(task.ID, stub, AuditExportTaskKey, []string{task.ID}); err != nil {
        return shim.Error(fmt.Sprintf("创建任务失败: %v", err))
    }

    // 写入状态索引
    if err := utils.WriteLedger(task.ID, stub, AuditExportTaskStatusIndexKey,
        []string{task.Status, task.CreateTime, task.ID}); err != nil {
        return shim.Error(fmt.Sprintf("写入索引失败: %v", err))
    }

    payload, _ := json.Marshal(task)
    return shim.Success(payload)
}

// UpdateAuditExportTaskStatus 更新导出任务状态
// args: [taskID, status, fileName, fileHash, failReason, finishTime]
func UpdateAuditExportTaskStatus(stub shim.ChaincodeStubInterface, args []string) pb.Response {
    if len(args) < 2 {
        return shim.Error("参数个数不满足")
    }

    taskID := args[0]
    newStatus := args[1]
    fileName := args[2]
    fileHash := args[3]
    failReason := args[4]
    finishTime := args[5]

    // 获取现有任务
    taskBytes, err := utils.GetStateByPartialCompositeKeys(stub, AuditExportTaskKey, []string{taskID})
    if err != nil || len(taskBytes) == 0 {
        return shim.Error("任务不存在")
    }

    var task AuditExportTask
    if err := json.Unmarshal(taskBytes[0], &task); err != nil {
        return shim.Error(fmt.Sprintf("任务解析失败: %v", err))
    }

    // 状态机校验
    validTransitions := map[string][]string{
        "PENDING":   {"RUNNING", "FAIL"},
        "RUNNING":   {"SUCCESS", "FAIL"},
        "SUCCESS":   {},
        "FAIL":      {},
    }

    allowed := false
    for _, s := range validTransitions[task.Status] {
        if s == newStatus {
            allowed = true
            break
        }
    }
    if !allowed {
        return shim.Error(fmt.Sprintf("状态转换不允许: %s -> %s", task.Status, newStatus))
    }

    // 删除旧索引
    _ = utils.DelLedger(stub, AuditExportTaskStatusIndexKey,
        []string{task.Status, task.CreateTime, task.ID})

    // 更新字段
    task.Status = newStatus
    if fileName != "" {
        task.FileName = fileName
    }
    if fileHash != "" {
        task.FileHash = fileHash
    }
    if failReason != "" {
        task.FailReason = failReason
    }
    if finishTime != "" {
        task.FinishTime = finishTime
    }

    // 写回
    if err := utils.WriteLedger(task.ID, stub, AuditExportTaskKey, []string{task.ID}); err != nil {
        return shim.Error(fmt.Sprintf("更新任务失败: %v", err))
    }

    // 写入新索引
    if err := utils.WriteLedger(task.ID, stub, AuditExportTaskStatusIndexKey,
        []string{task.Status, task.CreateTime, task.ID}); err != nil {
        return shim.Error(fmt.Sprintf("写入索引失败: %v", err))
    }

    payload, _ := json.Marshal(task)
    return shim.Success(payload)
}
```

