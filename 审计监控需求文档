```go
// queryByTimeRange 按时间范围查询
// args: [startTime, endTime, page, size]
func queryByTimeRange(stub shim.ChaincodeStubInterface, args []string) pb.Response {
    if len(args) < 4 {
        return shim.Error("参数个数不满足")
    }

    startTime := args[0]
    endTime := args[1]
    page, _ := strconv.Atoi(args[2])
    size, _ := strconv.Atoi(args[3])

    // 使用 GetStateByPartialCompositeKeysWithPagination 分页查询
    results, err := utils.GetStateByPartialCompositeKeysWithPagination(
        stub,
        AuditEventTimeIndexKey,
        []string{""}, // 时间索引需要特殊处理
        int32(size),
        []byte(""),
    )
    if err != nil {
        return shim.Error(fmt.Sprintf("查询失败: %v", err))
    }

    var events []AuditEvent
    for _, v := range results {
        var event AuditEvent
        if err := json.Unmarshal(v, &event); err != nil {
            continue
        }
        // 时间过滤
        if startTime != "" && event.EventTime < startTime {
            continue
        }
        if endTime != "" && event.EventTime > endTime {
            continue
        }
        events = append(events, event)
    }

    payload, _ := json.Marshal(events)
    return shim.Success(payload)
}
