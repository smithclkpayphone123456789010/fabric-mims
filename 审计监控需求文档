### 8.8 链码逻辑

```go
// AuditAlert 告警
type AuditAlert struct {
    ID              string `json:"id"`
    RuleCode        string `json:"rule_code"`
    Level           string `json:"level"`      // HIGH/MEDIUM/LOW
    Status          string `json:"status"`      // NEW/ACKED/RESOLVED
    TriggerTime     string `json:"trigger_time"`
    EventID         string `json:"event_id"`
    ActorID         string `json:"actor_id"`
    TargetPatientID string `json:"target_patient_id"`
    TargetRecordID  string `json:"target_record_id"`
    Description     string `json:"description"`
    HandleTime      string `json:"handle_time"`
    HandleNote      string `json:"handle_note"`
}

// 告警复合键常量
const (
    AuditAlertKey               = "audit-alert-key"
    AuditAlertStatusIndexKey    = "audit-alert-status-index-key"
    AuditAlertLevelIndexKey     = "audit-alert-level-index-key"
    AuditAlertTriggerTimeIndexKey = "audit-alert-trigger-time-index-key"
)

// CreateAuditAlert 创建告警
// args: [AuditAlert JSON]
func CreateAuditAlert(stub shim.ChaincodeStubInterface, args []string) pb.Response {
    if len(args) != 1 {
        return shim.Error("参数个数不满足")
    }

    var alert AuditAlert
    if err := json.Unmarshal([]byte(args[0]), &alert); err != nil {
        return shim.Error(fmt.Sprintf("告警解析失败: %v", err))
    }

    if alert.ID == "" {
        alert.ID = generateAlertID()
    }
    if alert.TriggerTime == "" {
        alert.TriggerTime = time.Now().Format("2006-01-02 15:04:05")
    }
    alert.Status = "NEW"

    // 写入主键
    if err := utils.WriteLedger(alert.ID, stub, AuditAlertKey, []string{alert.ID}); err != nil {
        return shim.Error(fmt.Sprintf("创建告警失败: %v", err))
    }

    // 写入索引
    if err := putAuditAlertIndexes(stub, &alert); err != nil {
        return shim.Error(fmt.Sprintf("写入索引失败: %v", err))
    }

    payload, _ := json.Marshal(alert)
    return shim.Success(payload)
}

// AckAlert 确认告警
// args: [alertID]
func AckAlert(stub shim.ChaincodeStubInterface, args []string) pb.Response {
    if len(args) != 1 {
        return shim.Error("参数个数不满足")
    }

    alertID := args[0]

    alert, err := getAlertByID(stub, alertID)
    if err != nil {
        return shim.Error("告警不存在")
    }

    if alert.Status != "NEW" {
        return shim.Error(fmt.Sprintf("当前状态不允许确认: %s", alert.Status))
    }

    // 删除旧索引
    _ = utils.DelLedger(stub, AuditAlertStatusIndexKey,
        []string{alert.Status, alert.TriggerTime, alert.ID})

    // 更新状态
    alert.Status = "ACKED"

    // 写回
    if err := utils.WriteLedger(alert.ID, stub, AuditAlertKey, []string{alert.ID}); err != nil {
        return shim.Error(fmt.Sprintf("更新告警失败: %v", err))
    }

    // 写入新索引
    if err := utils.WriteLedger(alert.ID, stub, AuditAlertStatusIndexKey,
        []string{alert.Status, alert.TriggerTime, alert.ID}); err != nil {
        return shim.Error(fmt.Sprintf("写入索引失败: %v", err))
    }

    payload, _ := json.Marshal(alert)
    return shim.Success(payload)
}

// ResolveAlert 关闭/解决告警
// args: [alertID, handleNote]
func ResolveAlert(stub shim.ChaincodeStubInterface, args []string) pb.Response {
    if len(args) != 2 {
        return shim.Error("参数个数不满足")
    }

    alertID := args[0]
    handleNote := args[1]

    if handleNote == "" {
        return shim.Error("处理备注不能为空")
    }

    alert, err := getAlertByID(stub, alertID)
    if err != nil {
        return shim.Error("告警不存在")
    }

    if alert.Status == "RESOLVED" {
        return shim.Error("告警已关闭")
    }

    // 删除旧索引
    _ = utils.DelLedger(stub, AuditAlertStatusIndexKey,
        []string{alert.Status, alert.TriggerTime, alert.ID})

    // 更新状态
    alert.Status = "RESOLVED"
    alert.HandleTime = time.Now().Format("2006-01-02 15:04:05")
    alert.HandleNote = handleNote

    // 写回
    if err := utils.WriteLedger(alert.ID, stub, AuditAlertKey, []string{alert.ID}); err != nil {
        return shim.Error(fmt.Sprintf("更新告警失败: %v", err))
    }

    // 写入新索引
    if err := utils.WriteLedger(alert.ID, stub, AuditAlertStatusIndexKey,
        []string{alert.Status, alert.TriggerTime, alert.ID}); err != nil {
        return shim.Error(fmt.Sprintf("写入索引失败: %v", err))
    }

    payload, _ := json.Marshal(alert)
    return shim.Success(payload)
}
```

